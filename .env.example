# Copy to .env and adjust.
# Gateway vars are read by services/gateway/src/polyglot_gateway/core/settings.py.

# --- Triton image ---
# Triton base image tag (services/serving/triton/Dockerfile). Bump to a tag on nvcr.io.
TRITON_VERSION=24.12-py3

# --- Backend registry ---
# Maps language pair keys to serving backends. Add new entries to support more pairs or backends.
# Supported types: "triton" (uses tritonclient.http), "vllm" (uses OpenAI-compatible API).
# Triton NMT (default) + vLLM for any direction via model="llm".
# Run `make vllm-up` to start the vLLM container before using the llm route.
BACKENDS='{"en-vi":{"type":"triton","url":"localhost:8000","model_name":"translator_en_vi"},"vi-en":{"type":"triton","url":"localhost:8000","model_name":"translator_vi_en"},"llm":{"type":"vllm","url":"localhost:8010","model_name":"Qwen/Qwen3.5-0.8B"}}'

# --- Pretrained HuggingFace checkpoints (for ONNX export only) ---
HF_MODEL_EN_VI=Helsinki-NLP/opus-mt-en-vi
HF_MODEL_VI_EN=Helsinki-NLP/opus-mt-vi-en

# --- Generation ---
MAX_NEW_TOKENS=512
NUM_BEAMS=1

# --- Queue / cache ---
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2
CACHE_TTL_SECONDS=86400

# --- Observability ---
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=changeme-grafana

# --- API ---
# Comma-separated list of accepted API keys (sent as X-API-Key header).
API_KEYS=changeme-dev-key
REQUEST_TIMEOUT_SECONDS=30
