# Copy to .env and adjust. All vars are read by src/envit5/core/settings.py (prefix ENVIT5_).

# --- Triton image / serving ---
# Triton base image tag (docker/triton.Dockerfile). Bump to a tag available on nvcr.io.
TRITON_VERSION=24.12-py3
ENVIT5_TRITON_HTTP_URL=localhost:8000
ENVIT5_TRITON_GRPC_URL=localhost:8001
ENVIT5_TRITON_MODEL_EN_VI=translator_en_vi
ENVIT5_TRITON_MODEL_VI_EN=translator_vi_en

# --- Pretrained HuggingFace checkpoints exported to ONNX ---
ENVIT5_HF_MODEL_EN_VI=Helsinki-NLP/opus-mt-en-vi
ENVIT5_HF_MODEL_VI_EN=Helsinki-NLP/opus-mt-vi-en

# --- Generation ---
ENVIT5_MAX_NEW_TOKENS=512
ENVIT5_NUM_BEAMS=1

# --- Queue / cache (Phase 3) ---
ENVIT5_REDIS_URL=redis://localhost:6379/0
ENVIT5_CELERY_BROKER_URL=redis://localhost:6379/1
ENVIT5_CELERY_RESULT_BACKEND=redis://localhost:6379/2
ENVIT5_CACHE_TTL_SECONDS=86400

# --- Observability ---
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=changeme-grafana

# --- API (Phase 3) ---
# Comma-separated list of accepted API keys (sent as X-API-Key).
ENVIT5_API_KEYS=changeme-dev-key
ENVIT5_REQUEST_TIMEOUT_SECONDS=30
