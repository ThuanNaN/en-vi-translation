{
  "annotations": { "list": [] },
  "description": "Application metrics for the EN↔VI translation service (FastAPI + Celery + Triton)",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "type": "timeseries",
      "title": "HTTP Request Rate",
      "description": "Requests per second by endpoint and status code",
      "id": 1,
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(rate(envit5_http_requests_total[$__rate_interval])) by (endpoint, status_code)",
          "legendFormat": "{{endpoint}} [{{status_code}}]",
          "refId": "A"
        }
      ],
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 1, "fillOpacity": 10, "showPoints": "never", "spanNulls": false }
        },
        "overrides": []
      }
    },
    {
      "type": "timeseries",
      "title": "HTTP Request Latency",
      "description": "P50 / P95 / P99 request latency by endpoint",
      "id": 2,
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "histogram_quantile(0.50, sum(rate(envit5_http_request_duration_seconds_bucket[$__rate_interval])) by (le, endpoint))",
          "legendFormat": "p50 {{endpoint}}",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "histogram_quantile(0.95, sum(rate(envit5_http_request_duration_seconds_bucket[$__rate_interval])) by (le, endpoint))",
          "legendFormat": "p95 {{endpoint}}",
          "refId": "B"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "histogram_quantile(0.99, sum(rate(envit5_http_request_duration_seconds_bucket[$__rate_interval])) by (le, endpoint))",
          "legendFormat": "p99 {{endpoint}}",
          "refId": "C"
        }
      ],
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 1, "fillOpacity": 10, "showPoints": "never", "spanNulls": false }
        },
        "overrides": []
      }
    },
    {
      "type": "timeseries",
      "title": "HTTP Error Rate",
      "description": "Fraction of 4xx + 5xx responses over all requests",
      "id": 3,
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(rate(envit5_http_requests_total{status_code=~\"[45]..\"}[$__rate_interval])) / sum(rate(envit5_http_requests_total[$__rate_interval]))",
          "legendFormat": "error rate",
          "refId": "A"
        }
      ],
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.01 },
              { "color": "red", "value": 0.05 }
            ]
          },
          "custom": { "lineWidth": 1, "fillOpacity": 20, "showPoints": "never", "spanNulls": false }
        },
        "overrides": []
      }
    },
    {
      "type": "timeseries",
      "title": "Translation Rate",
      "description": "Completed translation tasks per second by direction and status",
      "id": 4,
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(rate(envit5_translations_total[$__rate_interval])) by (direction, status)",
          "legendFormat": "{{direction}} [{{status}}]",
          "refId": "A"
        }
      ],
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 1, "fillOpacity": 10, "showPoints": "never", "spanNulls": false }
        },
        "overrides": []
      }
    },
    {
      "type": "timeseries",
      "title": "Translation Latency",
      "description": "P50 / P95 end-to-end translation task duration by direction",
      "id": 5,
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "histogram_quantile(0.50, sum(rate(envit5_translation_duration_seconds_bucket[$__rate_interval])) by (le, direction))",
          "legendFormat": "p50 {{direction}}",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "histogram_quantile(0.95, sum(rate(envit5_translation_duration_seconds_bucket[$__rate_interval])) by (le, direction))",
          "legendFormat": "p95 {{direction}}",
          "refId": "B"
        }
      ],
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 1, "fillOpacity": 10, "showPoints": "never", "spanNulls": false }
        },
        "overrides": []
      }
    },
    {
      "type": "timeseries",
      "title": "Cache Hit Rate",
      "description": "Redis translation cache hit fraction by direction",
      "id": 6,
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(rate(envit5_cache_hits_total[$__rate_interval])) by (direction) / (sum(rate(envit5_cache_hits_total[$__rate_interval])) by (direction) + sum(rate(envit5_cache_misses_total[$__rate_interval])) by (direction))",
          "legendFormat": "{{direction}}",
          "refId": "A"
        }
      ],
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 1, "fillOpacity": 10, "showPoints": "never", "spanNulls": false }
        },
        "overrides": []
      }
    },
    {
      "type": "timeseries",
      "title": "Triton Inference Latency",
      "description": "P50 / P95 per-chunk Triton inference duration by model",
      "id": 7,
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "histogram_quantile(0.50, sum(rate(envit5_triton_infer_duration_seconds_bucket[$__rate_interval])) by (le, model))",
          "legendFormat": "p50 {{model}}",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "histogram_quantile(0.95, sum(rate(envit5_triton_infer_duration_seconds_bucket[$__rate_interval])) by (le, model))",
          "legendFormat": "p95 {{model}}",
          "refId": "B"
        }
      ],
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 1, "fillOpacity": 10, "showPoints": "never", "spanNulls": false }
        },
        "overrides": []
      }
    },
    {
      "type": "stat",
      "title": "Active Translations",
      "description": "Currently in-flight translation tasks by direction",
      "id": 8,
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(envit5_active_translations) by (direction)",
          "legendFormat": "{{direction}}",
          "refId": "A"
        }
      ],
      "options": {
        "reduceOptions": { "values": false, "calcs": ["lastNotNull"], "fields": "" },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 2 },
              { "color": "red", "value": 4 }
            ]
          }
        },
        "overrides": []
      }
    },
    {
      "type": "timeseries",
      "title": "Text Chunks per Request",
      "description": "P50 / P95 number of chunks the chunker splits each request into",
      "id": 9,
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "histogram_quantile(0.50, sum(rate(envit5_text_chunks_bucket[$__rate_interval])) by (le, direction))",
          "legendFormat": "p50 {{direction}}",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "histogram_quantile(0.95, sum(rate(envit5_text_chunks_bucket[$__rate_interval])) by (le, direction))",
          "legendFormat": "p95 {{direction}}",
          "refId": "B"
        }
      ],
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 1, "fillOpacity": 10, "showPoints": "never", "spanNulls": false }
        },
        "overrides": []
      }
    }
  ],
  "refresh": "30s",
  "schemaVersion": 39,
  "tags": ["envit5", "translation"],
  "templating": { "list": [] },
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "EN↔VI Translation Service",
  "uid": "envit5-app",
  "version": 1
}
