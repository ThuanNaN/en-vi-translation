name: "translator_en_vi"
backend: "python"
max_batch_size: 16

input [
  {
    name: "INPUT_TEXT"
    data_type: TYPE_STRING
    dims: [ 1 ]
  }
]

output [
  {
    name: "OUTPUT_TEXT"
    data_type: TYPE_STRING
    dims: [ 1 ]
  }
]

# Let Triton coalesce concurrent requests into a single batch (up to ~max_batch_size)
# before invoking the model. Keep the queue delay small to bound latency.
dynamic_batching {
  max_queue_delay_microseconds: 100000
}

instance_group [
  {
    count: 1
    kind: KIND_GPU
  }
]

parameters [
  {
    key: "max_new_tokens"
    value: { string_value: "512" }
  },
  {
    key: "num_beams"
    value: { string_value: "1" }
  }
]
